FROM node:20-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

RUN npm run build && \
    mkdir -p /nginx-html && \
    cp -r "$(dirname "$(find /app/dist -name index.html | head -n 1)")"/* /nginx-html/

FROM nginx:1.27-alpine

COPY --from=build /nginx-html /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
